{
  "$schema": "https://json-schema.org/draft-07/schema",
  "title": "Agora AI model catalog",
  "type": "object",
  "required": ["lastUpdated", "models"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "lastUpdated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "_help": {
      "type": "string"
    },
    "_verifiedLegend": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "models": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "family", "label", "contextWindow", "maxOutputTokens", "verified"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "family": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "contextWindow": {
            "type": "integer",
            "minimum": 1
          },
          "maxOutputTokens": {
            "type": "integer",
            "minimum": 1
          },
          "verified": {
            "type": "string",
            "enum": ["official", "community", "unverified"]
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
