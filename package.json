{
  "name": "agora-backend",
  "version": "1.0.0",
  "description": "API de Agora para Cloud Run. Centraliza auth, documentos, workspaces, sync, pagos, cron jobs y Agora AI.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && tsc-alias --resolve-full-paths --resolve-full-extension .js",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "lint": "eslint \"src/**/*.ts\""
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@agora/contracts": "npm:@stevenvo780/agora-contracts@^1.0.2",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@stevenvo780/autologic": "^2.2.3",
    "@stevenvo780/st-lang": "^4.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "firebase-admin": "^13.7.0",
    "helmet": "^8.1.0",
    "ignore": "^7.0.5",
    "mammoth": "^1.11.0",
    "mercadopago": "^2.12.0",
    "pdf-parse": "^1.1.4",
    "turndown": "^7.2.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.10",
    "@types/pdf-parse": "^1.1.5",
    "@types/turndown": "^5.0.5",
    "@typescript-eslint/eslint-plugin": "8.46.1",
    "@typescript-eslint/parser": "8.46.1",
    "eslint": "^8.57.0",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.16.0",
    "typescript": "^5.5.3"
  }
}
