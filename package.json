{
  "name": "agora-backend",
  "version": "1.0.0",
  "description": "Servicio de IA agéntico de Agora (Cloud Run). Maneja conversaciones largas con OpenAI/Anthropic/Gemini/DeepSeek; las tools se delegan al hub Next.js via HTTP.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint \"src/**/*.ts\""
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
